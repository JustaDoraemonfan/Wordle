#include <bits/stdc++.h>
using namespace std;

#define MAX 10

struct Car {
    string num;
    int move = 0;
};

stack<Car> garage;

void arrival(string x) {
    if (garage.size() == MAX) {
        cout << "Garage full. " << x << " cannot enter\n";
        return;
    }
    garage.push({x, 0});
    cout << x << " arrived\n";
}

void departure(string x) {
    stack<Car> temp;
    bool found = false;
    if(garage.empty()){
        cout<<"Garage is empty no cars to return"<<endl;
        return;
    }
    while (!garage.empty()) {
        Car c = garage.top(); garage.pop();

        if (c.num == x) {
            cout << x << " departed after " << c.move << " moves\n";
            found = true;
            break;
        } else {
            c.move++;
            temp.push(c);
        }
    }

    while (!temp.empty()) {
        garage.push(temp.top());
        temp.pop();
    }

    if (!found)
        cout << x << " not found\n";
}

int main() {
    char ch;
    string x;

    while (1) {
        cout<<"press 'A' for arrival"<<endl<<"press 'D' for departure"<<endl<<"press 'Q' to stop"<<endl;
        cout<<"Enter your choice : ";
        cin>>ch;
        if (ch == 'Q') break;

        cout<<"Enter License Plate for Car : ";
        cin>>x;
        if (ch == 'A') arrival(x);
        else if (ch == 'D') departure(x);
    }
}
