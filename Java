import java.util.*;

public class ComputerSimulation {

    static class Transaction {
        int userId;
        int transactionNumber;
        int requestTime;
        int duration;

        Transaction(int userId, int transactionNumber, int requestTime, int duration) {
            this.userId = userId;
            this.transactionNumber = transactionNumber;
            this.requestTime = requestTime;
            this.duration = duration;
        }
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        System.out.print("Enter the number of users: ");
        int numUsers = scanner.nextInt();

        List<Transaction> allTransactions = new ArrayList<>();

        for (int i = 1; i <= numUsers; i++) {
            System.out.println("Enter data for User " + i);

            System.out.print("Enter user ID: ");
            int userId = scanner.nextInt();

            System.out.print("Enter starting time: ");
            int startingTime = scanner.nextInt();

            System.out.print("Enter the number of transactions: ");
            int numTransactions = scanner.nextInt();

            System.out.print("Enter the durations of the transactions: ");
            int[] durations = new int[numTransactions];
            for (int j = 0; j < numTransactions; j++) {
                durations[j] = scanner.nextInt();
            }

            allTransactions.add(new Transaction(userId, 1, startingTime, durations[0]));

            userDurations.put(userId, durations);
            userTransactionIndex.put(userId, 1);
            userStartingTime.put(userId, startingTime);
        }

        allTransactions.sort(Comparator.comparingInt(t -> t.requestTime));

        int currentTime = 0;
        double totalWaitingTime = 0;
        int totalTransactions = 0;

        PriorityQueue<Transaction> queue = new PriorityQueue<>(Comparator.comparingInt(t -> t.requestTime));
        queue.addAll(allTransactions);

        while (!queue.isEmpty()) {
            Transaction t = queue.poll();

            if (currentTime < t.requestTime) {
                currentTime = t.requestTime;
            }

            int startTime = currentTime;
            int endTime = currentTime + t.duration;
            int waitingTime = startTime - t.requestTime;

            System.out.printf("User %d Transaction %d: Start time: %d End time: %d " +
                    "Waiting time: %d - %d = %d seconds%n",
                    t.userId, t.transactionNumber,
                    startTime, endTime,
                    startTime, t.requestTime, waitingTime);

            totalWaitingTime += waitingTime;
            totalTransactions++;
            currentTime = endTime;

            int[] durations = userDurations.get(t.userId);
            int nextIndex = userTransactionIndex.get(t.userId);

            if (nextIndex < durations.length) {
                Transaction next = new Transaction(t.userId, nextIndex + 1, endTime, durations[nextIndex]);
                userTransactionIndex.put(t.userId, nextIndex + 1);
                queue.add(next);
            }
        }

        double avgWaitingTime = totalWaitingTime / totalTransactions;
        System.out.printf("Average waiting time: %.2f seconds%n", avgWaitingTime);

        scanner.close();
    }

    static Map<Integer, int[]> userDurations = new HashMap<>();
    static Map<Integer, Integer> userTransactionIndex = new HashMap<>();
    static Map<Integer, Integer> userStartingTime = new HashMap<>();
}






import java.util.*;

public class ComputerSimulation {

    static class User {
        int userId;
        int startingTime;
        int[] durations;

        User(int userId, int startingTime, int[] durations) {
            this.userId = userId;
            this.startingTime = startingTime;
            this.durations = durations;
        }
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        System.out.print("Enter the number of users: ");
        int numUsers = scanner.nextInt();

        List<User> users = new ArrayList<>();

        for (int i = 1; i <= numUsers; i++) {
            System.out.println("Enter data for User " + i);

            System.out.print("Enter user ID: ");
            int userId = scanner.nextInt();

            System.out.print("Enter starting time: ");
            int startingTime = scanner.nextInt();

            System.out.print("Enter the number of transactions: ");
            int numTransactions = scanner.nextInt();

            System.out.print("Enter the durations of the transactions: ");
            int[] durations = new int[numTransactions];
            for (int j = 0; j < numTransactions; j++) {
                durations[j] = scanner.nextInt();
            }

            users.add(new User(userId, startingTime, durations));
        }

        int currentTime = 0;
        double totalWaitingTime = 0;
        int totalTransactions = 0;

        // Process each user fully before moving to the next
        for (User user : users) {

            // Computer can't start before the user arrives
            if (currentTime < user.startingTime) {
                currentTime = user.startingTime;
            }

            // requestTime for first transaction is the user's starting time
            int requestTime = user.startingTime;

            for (int i = 0; i < user.durations.length; i++) {
                int startTime = currentTime;
                int endTime = currentTime + user.durations[i];
                int waitingTime = startTime - requestTime;

                System.out.printf("User %d Transaction %d: Start time: %d End time: %d " +
                        "Waiting time: %d - %d = %d seconds%n",
                        user.userId, i + 1,
                        startTime, endTime,
                        startTime, requestTime, waitingTime);

                totalWaitingTime += waitingTime;
                totalTransactions++;

                currentTime = endTime;
                // Next transaction is requested as soon as the current one ends
                requestTime = endTime;
            }
        }

        double avgWaitingTime = totalWaitingTime / totalTransactions;
        System.out.printf("Average waiting time: %.2f seconds%n", avgWaitingTime);

        scanner.close();
    }
}

