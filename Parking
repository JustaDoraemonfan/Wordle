/*
 * Bashemin Parking Garage Simulator
 *
 * Models a single-lane garage holding up to 10 cars.
 * There is only one entrance/exit at one end of the lane.
 * The lane is modelled as an array used as a stack:
 *   lane[0]       = back of lane (farthest from exit)
 *   lane[top - 1] = nearest to exit
 *
 * Input format per line:
 *   A <plate>   - car arrives
 *   D <plate>   - car departs
 *
 * On arrival:  prints whether car was stored or turned away (garage full).
 * On departure: prints how many times the car was moved out during retrieval.
 */

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

#define MAX_CAPACITY  10
#define MAX_PLATE_LEN 16
#define MAX_LINE_LEN  64

/* ------------------------------------------------------------------ */
/* Data structures                                                      */
/* ------------------------------------------------------------------ */

/* The garage lane. lane[0] = back, lane[top-1] = nearest exit. */
static char lane[MAX_CAPACITY][MAX_PLATE_LEN];
static int  lane_top = 0;   /* number of cars currently in lane */

/* Temporary stack used when displacing cars */
static char temp_stack[MAX_CAPACITY][MAX_PLATE_LEN];
static int  temp_top = 0;

/* ------------------------------------------------------------------ */
/* Helper utilities                                                     */
/* ------------------------------------------------------------------ */

/* Convert string to upper case in-place */
static void str_upper(char *s) {
    for (; *s; s++) *s = (char)toupper((unsigned char)*s);
}

/* Return index of plate in lane[], or -1 if not found */
static int find_in_lane(const char *plate) {
    for (int i = 0; i < lane_top; i++) {
        if (strcmp(lane[i], plate) == 0) return i;
    }
    return -1;
}

/* ------------------------------------------------------------------ */
/* Arrival logic                                                        */
/* ------------------------------------------------------------------ */

/*
 * Add the car to the BACK of the lane (index 0 side).
 * We do this by:
 *   1. Popping all existing cars into temp_stack.
 *   2. Placing the new car at lane[0].
 *   3. Pushing everything from temp_stack back on top.
 * This keeps the exit end (top of lane) intact.
 */
static void process_arrival(const char *plate) {
    printf("Car %s has arrived.\n", plate);

    if (lane_top >= MAX_CAPACITY) {
        printf("  -> No room available. Car %s departs without entering.\n\n", plate);
        return;
    }

    /* Move all current cars to temp */
    temp_top = 0;
    while (lane_top > 0) {
        lane_top--;
        strncpy(temp_stack[temp_top], lane[lane_top], MAX_PLATE_LEN - 1);
        temp_stack[temp_top][MAX_PLATE_LEN - 1] = '\0';
        temp_top++;
    }

    /* Place new car at the back (base of lane array) */
    strncpy(lane[0], plate, MAX_PLATE_LEN - 1);
    lane[0][MAX_PLATE_LEN - 1] = '\0';
    lane_top = 1;

    /* Restore other cars on top */
    while (temp_top > 0) {
        temp_top--;
        strncpy(lane[lane_top], temp_stack[temp_top], MAX_PLATE_LEN - 1);
        lane[lane_top][MAX_PLATE_LEN - 1] = '\0';
        lane_top++;
    }

    printf("  -> Car %s stored in garage. (%d/%d spaces used)\n\n",
           plate, lane_top, MAX_CAPACITY);
}

/* ------------------------------------------------------------------ */
/* Departure logic                                                      */
/* ------------------------------------------------------------------ */

/*
 * Remove the target car from the lane.
 * Cars above it (closer to exit) are popped into temp_stack,
 * the target is removed, then temp_stack cars are restored.
 */
static void process_departure(const char *plate) {
    printf("Car %s is departing.\n", plate);

    if (find_in_lane(plate) < 0) {
        printf("  -> Car %s is not in the garage.\n\n", plate);
        return;
    }

    temp_top = 0;
    int move_count = 0;

    /* Pop cars from exit end until we reach the target */
    while (lane_top > 0 && strcmp(lane[lane_top - 1], plate) != 0) {
        lane_top--;
        strncpy(temp_stack[temp_top], lane[lane_top], MAX_PLATE_LEN - 1);
        temp_stack[temp_top][MAX_PLATE_LEN - 1] = '\0';
        temp_top++;
        move_count++;
        printf("  [move] Car %s moved out temporarily.\n", temp_stack[temp_top - 1]);
    }

    /* Remove the target car */
    lane_top--;
    printf("  -> Car %s driven out.\n", plate);

    /* Restore displaced cars in their original order */
    while (temp_top > 0) {
        temp_top--;
        strncpy(lane[lane_top], temp_stack[temp_top], MAX_PLATE_LEN - 1);
        lane[lane_top][MAX_PLATE_LEN - 1] = '\0';
        printf("  [restore] Car %s moved back in.\n", lane[lane_top]);
        lane_top++;
    }

    printf("  -> Car %s has left. It was moved out %d time(s). (%d/%d spaces used)\n\n",
           plate, move_count, lane_top, MAX_CAPACITY);
}

/* ------------------------------------------------------------------ */
/* Main                                                                 */
/* ------------------------------------------------------------------ */

int main(void) {
    char line[MAX_LINE_LEN];
    char action[4];
    char plate[MAX_PLATE_LEN];

    printf("Bashemin Parking Garage\n");
    printf("=======================\n");
    printf("Enter commands (A <plate> or D <plate>). EOF to quit.\n\n");

    while (fgets(line, sizeof(line), stdin) != NULL) {
        /* Skip blank lines */
        if (line[0] == '\n' || line[0] == '\r') continue;

        /* Parse action and plate */
        if (sscanf(line, "%3s %15s", action, plate) != 2) {
            printf("Invalid input: %s", line);
            continue;
        }

        str_upper(action);
        str_upper(plate);

        if (strcmp(action, "A") == 0) {
            process_arrival(plate);
        } else if (strcmp(action, "D") == 0) {
            process_departure(plate);
        } else {
            printf("Unknown action '%s'. Use A or D.\n\n", action);
        }
    }

    printf("Garage closed.\n");
    return 0;
}
