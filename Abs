abstract class ThreeDObject {
    private double d1, d2, d3;

    public ThreeDObject() {}

    public ThreeDObject(double d1, double d2, double d3) {
        this.d1 = d1;
        this.d2 = d2;
        this.d3 = d3;
    }

    public double getD1() { return d1; }
    public double getD2() { return d2; }
    public double getD3() { return d3; }

    public void setD1(double d1) { this.d1 = d1; }
    public void setD2(double d2) { this.d2 = d2; }
    public void setD3(double d3) { this.d3 = d3; }

    public abstract double volume();
    public abstract double wholeSurfaceArea();
}
class Box extends ThreeDObject {

    public Box() {}

    public Box(double l, double b, double h) {
        super(l, b, h);
    }

    public double volume() {
        return getD1() * getD2() * getD3();
    }

    public double wholeSurfaceArea() {
        double l = getD1(), b = getD2(), h = getD3();
        return 2 * (l*b + b*h + h*l);
    }
}
class Cube extends ThreeDObject {

    public Cube() {}

    public Cube(double side) {
        super(side, 0, 0);
    }

    public double volume() {
        return Math.pow(getD1(), 3);
    }

    public double wholeSurfaceArea() {
        return 6 * getD1() * getD1();
    }
}
class Cylinder extends ThreeDObject {

    public Cylinder() {}

    public Cylinder(double r, double h) {
        super(r, h, 0);
    }

    public double volume() {
        return Math.PI * getD1() * getD1() * getD2();
    }

    public double wholeSurfaceArea() {
        return 2 * Math.PI * getD1() * (getD1() + getD2());
    }
}
class Cone extends ThreeDObject {

    public Cone() {}

    public Cone(double r, double h) {
        super(r, h, 0);
    }

    public double volume() {
        return (Math.PI * getD1() * getD1() * getD2()) / 3;
    }

    public double wholeSurfaceArea() {
        double r = getD1(), h = getD2();
        double l = Math.sqrt(r*r + h*h);
        return Math.PI * r * (r + l);
    }
}

import java.util.Scanner;

public class Driver1 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int choice;

        do {
            System.out.println("\n1. Box\n2. Cube\n3. Cylinder\n4. Cone\n5. Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            switch(choice) {
                case 1:
                    System.out.print("Enter length, breadth, height: ");
                    Box b = new Box(sc.nextDouble(), sc.nextDouble(), sc.nextDouble());
                    System.out.println("Volume: " + b.volume());
                    System.out.println("Surface Area: " + b.wholeSurfaceArea());
                    break;

                case 2:
                    System.out.print("Enter side: ");
                    Cube c = new Cube(sc.nextDouble());
                    System.out.println("Volume: " + c.volume());
                    System.out.println("Surface Area: " + c.wholeSurfaceArea());
                    break;

                case 3:
                    System.out.print("Enter radius and height: ");
                    Cylinder cy = new Cylinder(sc.nextDouble(), sc.nextDouble());
                    System.out.println("Volume: " + cy.volume());
                    System.out.println("Surface Area: " + cy.wholeSurfaceArea());
                    break;

                case 4:
                    System.out.print("Enter radius and height: ");
                    Cone co = new Cone(sc.nextDouble(), sc.nextDouble());
                    System.out.println("Volume: " + co.volume());
                    System.out.println("Surface Area: " + co.wholeSurfaceArea());
                    break;
            }

        } while(choice != 5);
    }
}




