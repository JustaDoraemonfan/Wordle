#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>

#define PORT 25020

// ------------------ STACK ------------------
char stack[100];
int stackTop = -1;

int precedence(char op){
    if(op == '+' || op == '-') return 1;
    if(op == '*' || op == '/') return 2;
    return 0;
}

// ------------------ INFIX TO POSTFIX ------------------
void infixToPostfix(char *infix, char *postfix){
    int i = 0, k = 0;
    char ch;

    stackTop = -1;

    while((ch = infix[i++]) != '\0'){
        if(ch >= '0' && ch <= '9'){
            postfix[k++] = ch;
        }
        else if(ch == '('){
            stack[++stackTop] = ch;
        }
        else if(ch == ')'){
            while(stackTop != -1 && stack[stackTop] != '('){
                postfix[k++] = stack[stackTop--];
            }
            stackTop--; // remove '('
        }
        else{
            while(stackTop != -1 && precedence(stack[stackTop]) >= precedence(ch)){
                postfix[k++] = stack[stackTop--];
            }
            stack[++stackTop] = ch;
        }
    }

    while(stackTop != -1){
        postfix[k++] = stack[stackTop--];
    }

    postfix[k] = '\0';
}

// ------------------ POSTFIX EVALUATION ------------------
int evaluatePostfix(char *postfix){
    int result[100];
    int t = 0;
    int j = 0;
    char c;

    while((c = postfix[j++]) != '\0'){
        if(c >= '0' && c <= '9'){
            result[t++] = c - '0';
        }
        else{
            int b = result[--t];
            int a = result[--t];
            int eval = 0;

            switch(c){
                case '+': eval = a + b; break;
                case '-': eval = a - b; break;
                case '*': eval = a * b; break;
                case '/': eval = a / b; break;
            }

            result[t++] = eval;
        }
    }

    return result[t-1];
}

// ------------------ MAIN SERVER ------------------
int main(){
    int listenfd, connfd, r;
    struct sockaddr_in serv_addr, cli_addr;
    socklen_t cli_len;

    char buff[128], postfix[128];

    listenfd = socket(AF_INET, SOCK_STREAM, 0);

    serv_addr.sin_family = AF_INET;
    serv_addr.sin_addr.s_addr = INADDR_ANY;
    serv_addr.sin_port = htons(PORT);

    bind(listenfd, (struct sockaddr*)&serv_addr, sizeof(serv_addr));
    listen(listenfd, 5);

    printf("Server running on port %d...\n", PORT);

    while(1){
        cli_len = sizeof(cli_addr);

        connfd = accept(listenfd, (struct sockaddr*)&cli_addr, &cli_len);

        if(connfd < 0) continue;

        if(fork() == 0){
            close(listenfd); // child doesn't need listener

            while(1){
                r = read(connfd, buff, sizeof(buff)-1);

                if(r <= 0){
                    printf("Client disconnected.\n");
                    break;
                }

                buff[r] = '\0';

                printf("Client: %s\n", buff);

                // EXIT COMMAND
                if(strncmp(buff, "exit", 4) == 0){
                    printf("Client requested exit.\n");
                    break;
                }

                // PROCESS EXPRESSION
                infixToPostfix(buff, postfix);
                int result = evaluatePostfix(postfix);

                sprintf(buff, "Result = %d\n", result);

                write(connfd, buff, strlen(buff));
            }

            close(connfd);
            exit(0);
        }

        close(connfd); // parent continues
    }

    close(listenfd);
    return 0;
}


#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>

#define PORT 25020

int main(){
    int skfd, r;
    struct sockaddr_in serv_addr;

    char sbuff[128], rbuff[128];

    skfd = socket(AF_INET, SOCK_STREAM, 0);

    serv_addr.sin_family = AF_INET;
    serv_addr.sin_port = htons(PORT);
    serv_addr.sin_addr.s_addr = inet_addr("127.0.0.1");

    if(connect(skfd, (struct sockaddr*)&serv_addr, sizeof(serv_addr)) < 0){
        printf("Connection failed\n");
        return 0;
    }

    printf("Connected to server.\n");

    while(1){
        printf("\nEnter expression (or 'exit'): ");
        fgets(sbuff, sizeof(sbuff), stdin);

        sbuff[strcspn(sbuff, "\n")] = 0; // remove newline

        write(skfd, sbuff, strlen(sbuff));

        if(strcmp(sbuff, "exit") == 0){
            printf("Exiting...\n");
            break;
        }

        r = read(skfd, rbuff, sizeof(rbuff)-1);

        if(r <= 0){
            printf("\nServer disconnected. Exiting...\n");
            break;
        }

        rbuff[r] = '\0';

        printf("Server: %s", rbuff);
    }

    close(skfd);
    return 0;
}
