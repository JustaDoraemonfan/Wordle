import java.util.Scanner;

class Call {
    private int duration;

    public Call() {}

    public Call(int duration) {
        this.duration = duration;
    }

    public int getDuration() {
        return duration;
    }

    public void setDuration(int duration) {
        this.duration = duration;
    }
}

// Local Call
class LocalCall extends Call {

    public LocalCall() {}

    public LocalCall(int duration) {
        super(duration);
    }

    public int calculateUnits() {
        int duration = getDuration();
        return (int) Math.ceil(duration / 3.0); // 1 unit per 3 min
    }
}

// Long Distance Call
class LongDistanceCall extends Call {
    private String time;
    private int originCode;
    private int destCode;

    public LongDistanceCall() {}

    public LongDistanceCall(int duration, String time, int originCode, int destCode) {
        super(duration);
        this.time = time;
        this.originCode = originCode;
        this.destCode = destCode;
    }

    public double calculateBill() {
        double rate;

        if (time.equalsIgnoreCase("day")) {
            rate = 2.0;
        } else {
            rate = 1.5;
        }

        return getDuration() * rate;
    }
}

public class Driver2 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Local Call
        System.out.print("Enter local call duration (minutes): ");
        int localDur = sc.nextInt();

        LocalCall lc = new LocalCall(localDur);
        System.out.println("Local call units: " + lc.calculateUnits());

        // STD Call
        System.out.print("Enter STD call duration: ");
        int stdDur = sc.nextInt();

        sc.nextLine(); // clear buffer

        System.out.print("Enter time (day/night): ");
        String time = sc.nextLine();

        System.out.print("Enter origin STD code: ");
        int o = sc.nextInt();

        System.out.print("Enter destination STD code: ");
        int d = sc.nextInt();

        LongDistanceCall ldc = new LongDistanceCall(stdDur, time, o, d);
        System.out.println("STD Call Bill: " + ldc.calculateBill());
    }
}


