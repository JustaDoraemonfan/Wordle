import java.util.Scanner;

class MyClass {

    // Default constructor
    public MyClass() {}

    // Parameterized constructor (not really needed but added as per rules)
    public MyClass(int dummy) {}

    // Method for int
    public int abs(int x) {
        return (x < 0) ? -x : x;
    }

    // Method for float
    public float abs(float x) {
        return (x < 0) ? -x : x;
    }

    // Method for double
    public double abs(double x) {
        return (x < 0) ? -x : x;
    }
}

public class Driver1 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        MyClass obj = new MyClass();

        System.out.print("Enter integer: ");
        int i = sc.nextInt();

        System.out.print("Enter float: ");
        float f = sc.nextFloat();

        System.out.print("Enter double: ");
        double d = sc.nextDouble();

        System.out.println("Absolute int: " + obj.abs(i));
        System.out.println("Absolute float: " + obj.abs(f));
        System.out.println("Absolute double: " + obj.abs(d));
    }
}


