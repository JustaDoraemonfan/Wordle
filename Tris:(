#include<stdio.h>
#include<limits.h>
#define V 7
#define E 10
#define inf INT_MAX/2

struct Edge{
  int u, v, w;
};

struct Edge edge[E] = {
    {1,2,6},
    {1,3,5},
    {1,4,5},
    {3,2,-2},   
    {4,3,-2},
    {2,5,-1},
    {3,5,1},
    {4,6,-1},
    {5,7,3},
    {6,7,3}
};

int table[V-1][V+1];
void b(int src){
  int d[V+1], nd[V+1], pa[V+1];

  for(int i = 1; i <= V; i++){
    d[i] = inf;
    pa[i] = -1;
  }

  d[src] = 0;

  for(int i = 0; i < V-1; i++){

    for(int j = 1; j <= V; j++){
      nd[j] = d[j];
    }

    for(int j = 0; j < E; j++){
      int u = edge[j].u;
      int v = edge[j].v;
      int w = edge[j].w;

      if(d[u] != inf && d[u] + w < nd[v]){
        nd[v] = d[u] + w;
        pa[v] = u;
      }
    }

    for(int j = 1; j <= V; j++){
      d[j] = nd[j];
      table[i][j] = d[j];
    }
  }

  printf("\nk\t1->1\t1->2\t1->3\t1->4\t1->5\t1->6\t1->7\n");
  for(int i = 0; i < V-1; i++){
    printf("%d\t",i+1);
    for(int j = 1; j <= V; j++){
      if(table[i][j] >= inf) printf("INF\t");
      else printf("%d\t",table[i][j]);
    }
    printf("\n");
  }

  printf("Path :\n");
  for(int i = 1; i <= V; i++){
    if(i == src) continue;

    int p[V], k = 0, temp = i;
    while(temp != -1){
      p[k++] = temp;
      temp = pa[temp];
    }

    for(int j = k-1; j >= 0; j--){
      printf("%d",p[j]);
      if(j>0) printf("->");
    }
    printf(":%d\n",d[i]);
  }
}

int main(){
  b(1);
  return 0;
}
