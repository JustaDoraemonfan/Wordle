import java.util.*;

abstract class ThreeDObject {
    protected double a, b, c; // dimensions

    abstract double volume();
    abstract double wholeSurfaceArea();
}

// Box
class Box extends ThreeDObject {
    Box(double l, double w, double h) {
        a = l; b = w; c = h;
    }

    double volume() {
        return a * b * c;
    }

    double wholeSurfaceArea() {
        return 2 * (a*b + b*c + a*c);
    }
}

// Cube
class Cube extends ThreeDObject {
    Cube(double side) {
        a = side;
    }

    double volume() {
        return a * a * a;
    }

    double wholeSurfaceArea() {
        return 6 * a * a;
    }
}

// Cylinder
class Cylinder extends ThreeDObject {
    Cylinder(double r, double h) {
        a = r; b = h;
    }

    double volume() {
        return Math.PI * a * a * b;
    }

    double wholeSurfaceArea() {
        return 2 * Math.PI * a * (a + b);
    }
}

// Cone
class Cone extends ThreeDObject {
    Cone(double r, double h) {
        a = r; b = h;
    }

    double volume() {
        return (1.0/3) * Math.PI * a * a * b;
    }

    double wholeSurfaceArea() {
        double l = Math.sqrt(a*a + b*b);
        return Math.PI * a * (a + l);
    }
}

// Driver Class (Menu Driven)
public class Main3D {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int choice;

        do {
            System.out.println("\n1.Box 2.Cube 3.Cylinder 4.Cone 5.Exit");
            System.out.print("Enter choice: ");
            choice = sc.nextInt();

            ThreeDObject obj = null;

            switch(choice) {
                case 1:
                    System.out.print("Enter l w h: ");
                    obj = new Box(sc.nextDouble(), sc.nextDouble(), sc.nextDouble());
                    break;

                case 2:
                    System.out.print("Enter side: ");
                    obj = new Cube(sc.nextDouble());
                    break;

                case 3:
                    System.out.print("Enter radius height: ");
                    obj = new Cylinder(sc.nextDouble(), sc.nextDouble());
                    break;

                case 4:
                    System.out.print("Enter radius height: ");
                    obj = new Cone(sc.nextDouble(), sc.nextDouble());
                    break;

                case 5:
                    System.out.println("Exit");
                    break;

                default:
                    System.out.println("Invalid choice");
            }

            if(obj != null) {
                System.out.println("Volume = " + obj.volume());
                System.out.println("Surface Area = " + obj.wholeSurfaceArea());
            }

        } while(choice != 5);

        sc.close();
    }
}
